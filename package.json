{
  "name": "explore",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/mail-client": "^3.24.0",
    "@sap/cds": "^9.8.3",
    "@sap/xsenv": "^5.6.1",
    "@sap/xssec": "^4",
    "express": "^4",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.10.0",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^9.8.1",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-productlistui": "cds watch --open productlistui/webapp/index.html?sap-ui-xx-viewCache=false",
    "undeploy": "cf undeploy explore --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "auth": {
        "[production]": {
          "kind": "xsuaa"
        },
        "[development]": {
          "kind": "mocked"
        }
      },
      "destinations": true
    }
  },
  "sapux": [
    "app/productlistui"
  ]
}
